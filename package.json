{
  "name": "axicharts",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "storybook": "pnpm --filter @axicharts/storybook dev",
    "dashboarder": "pnpm --filter @axicharts/dashboarder dev",
    "planner": "pnpm --filter @axicharts/charts-planner exec charts-planner serve",
    "mcp": "pnpm --filter @axicharts/charts-mcp exec charts-mcp",
    "docs": "pnpm --filter @axicharts/docs dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:perf": "pnpm --filter @axicharts/charts-canvas test:perf",
    "bench": "node scripts/collect-benchmarks.mjs",
    "bench:browser": "node benchmarks/browser/run.mjs",
    "bench:stability": "node benchmarks/browser/stability.mjs",
    "test:e2e:share-import": "node benchmarks/e2e/share-import.mjs",
    "test:visual": "node benchmarks/e2e/visual-snapshots.mjs",
    "test:registry": "node scripts/test-registry-e2e.mjs",
    "bench:all": "node scripts/collect-benchmarks.mjs --browser",
    "size": "size-limit",
    "validate:runtime": "pnpm --filter @axicharts/charts-runtime validate:examples",
    "typecheck": "turbo run typecheck",
    "ci": "pnpm build && pnpm test && pnpm test:perf && pnpm size && pnpm validate:runtime && pnpm test:registry && pnpm test:visual",
    "create:dashboard": "node packages/charts/scripts/create-dashboard.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@size-limit/file": "^11.1.6",
    "playwright": "^1.51.1",
    "shadcn": "^4.13.1",
    "size-limit": "^11.1.6",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
