{
  "name": "@axicharts/charts",
  "version": "0.4.1",
  "description": "Composable React charts for dashboards — Recharts/shadcn alternative with live canvas, spec JSON, and industrial primitives.",
  "keywords": [
    "react",
    "charts",
    "dashboard",
    "recharts",
    "shadcn",
    "uplot",
    "echarts",
    "live-charts",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axidify/axicharts.git",
    "directory": "packages/charts"
  },
  "bugs": {
    "url": "https://github.com/Axidify/axicharts/issues"
  },
  "homepage": "https://github.com/Axidify/axicharts#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "README.md"
  ],
  "bin": {
    "create-dashboard": "./bin/create-dashboard.mjs"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./line": {
      "types": "./dist/entry/line.d.ts",
      "import": "./dist/entry/line.js"
    },
    "./bar": {
      "types": "./dist/entry/bar.d.ts",
      "import": "./dist/entry/bar.js"
    },
    "./pie": {
      "types": "./dist/entry/pie.d.ts",
      "import": "./dist/entry/pie.js"
    },
    "./area": {
      "types": "./dist/entry/area.d.ts",
      "import": "./dist/entry/area.js"
    },
    "./candlestick": {
      "types": "./dist/entry/candlestick.d.ts",
      "import": "./dist/entry/candlestick.js"
    },
    "./waterfall": {
      "types": "./dist/entry/waterfall.d.ts",
      "import": "./dist/entry/waterfall.js"
    },
    "./heatmap": {
      "types": "./dist/entry/heatmap.d.ts",
      "import": "./dist/entry/heatmap.js"
    },
    "./calendar": {
      "types": "./dist/entry/calendar.d.ts",
      "import": "./dist/entry/calendar.js"
    },
    "./pictorial-bar": {
      "types": "./dist/entry/pictorial-bar.d.ts",
      "import": "./dist/entry/pictorial-bar.js"
    },
    "./liquid-fill": {
      "types": "./dist/entry/liquid-fill.d.ts",
      "import": "./dist/entry/liquid-fill.js"
    },
    "./bump": {
      "types": "./dist/entry/bump.d.ts",
      "import": "./dist/entry/bump.js"
    },
    "./violin": {
      "types": "./dist/entry/violin.d.ts",
      "import": "./dist/entry/violin.js"
    },
    "./swarm": {
      "types": "./dist/entry/swarm.d.ts",
      "import": "./dist/entry/swarm.js"
    },
    "./ridgeline": {
      "types": "./dist/entry/ridgeline.d.ts",
      "import": "./dist/entry/ridgeline.js"
    },
    "./network": {
      "types": "./dist/entry/network.d.ts",
      "import": "./dist/entry/network.js"
    },
    "./export": {
      "types": "./dist/entry/export.d.ts",
      "import": "./dist/entry/export.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.js"
    },
    "./cartesian": {
      "types": "./dist/entry/cartesian.d.ts",
      "import": "./dist/entry/cartesian.js"
    },
    "./distribution": {
      "types": "./dist/entry/distribution.d.ts",
      "import": "./dist/entry/distribution.js"
    },
    "./financial": {
      "types": "./dist/entry/financial.d.ts",
      "import": "./dist/entry/financial.js"
    },
    "./matrix": {
      "types": "./dist/entry/matrix.d.ts",
      "import": "./dist/entry/matrix.js"
    },
    "./industrial": {
      "types": "./dist/entry/industrial.d.ts",
      "import": "./dist/entry/industrial.js"
    },
    "./kpi": {
      "types": "./dist/entry/kpi.d.ts",
      "import": "./dist/entry/kpi.js"
    },
    "./full": {
      "types": "./dist/entry/full.d.ts",
      "import": "./dist/entry/full.js"
    },
    "./quick": {
      "types": "./dist/entry/quick.d.ts",
      "import": "./dist/entry/quick.js"
    },
    "./studio": {
      "types": "./dist/entry/studio.d.ts",
      "import": "./dist/entry/studio.js"
    },
    "./motion": {
      "types": "./dist/entry/motion.d.ts",
      "import": "./dist/entry/motion.js"
    },
    "./echarts-option": {
      "types": "./dist/entry/echarts-option.d.ts",
      "import": "./dist/entry/echarts-option.js"
    },
    "./graphic": {
      "types": "./dist/entry/graphic.d.ts",
      "import": "./dist/entry/graphic.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/registry/index.ts src/entry/line.ts src/entry/bar.ts src/entry/pie.ts src/entry/area.ts src/entry/candlestick.ts src/entry/waterfall.ts src/entry/heatmap.ts src/entry/calendar.ts src/entry/pictorial-bar.ts src/entry/liquid-fill.ts src/entry/bump.ts src/entry/violin.ts src/entry/swarm.ts src/entry/ridgeline.ts src/entry/network.ts src/entry/export.ts src/entry/cartesian.ts src/entry/distribution.ts src/entry/financial.ts src/entry/matrix.ts src/entry/industrial.ts src/entry/kpi.ts src/entry/full.ts src/entry/quick.ts src/entry/studio.ts src/entry/motion.ts src/entry/echarts-option.ts src/entry/graphic.ts --format esm --dts --external react --external react-dom --external uplot --external echarts --external jspdf --clean",
    "dev": "tsup src/index.ts src/registry/index.ts src/entry/line.ts src/entry/bar.ts src/entry/pie.ts src/entry/area.ts src/entry/candlestick.ts src/entry/waterfall.ts src/entry/heatmap.ts src/entry/calendar.ts src/entry/pictorial-bar.ts src/entry/liquid-fill.ts src/entry/bump.ts src/entry/violin.ts src/entry/swarm.ts src/entry/ridgeline.ts src/entry/network.ts src/entry/export.ts src/entry/cartesian.ts src/entry/distribution.ts src/entry/financial.ts src/entry/matrix.ts src/entry/industrial.ts src/entry/kpi.ts src/entry/full.ts src/entry/quick.ts src/entry/studio.ts src/entry/motion.ts src/entry/echarts-option.ts src/entry/graphic.ts --format esm --dts --external react --external react-dom --external uplot --external echarts --external jspdf --watch",
    "create-dashboard": "node scripts/create-dashboard.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "echarts": "^5.5.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "uplot": "^1.6.31"
  },
  "dependencies": {
    "@axicharts/charts-canvas": "workspace:*",
    "@axicharts/charts-core": "workspace:*",
    "@axicharts/charts-echarts": "workspace:*",
    "@axicharts/charts-theme": "workspace:*",
    "jspdf": "^3.0.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "echarts": "^5.6.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "uplot": "^1.6.31",
    "vitest": "^3.0.8"
  }
}
