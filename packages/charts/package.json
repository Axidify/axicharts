{
  "name": "@axicharts/charts",
  "version": "0.3.15",
  "description": "Composable React charts for dashboards — Recharts/shadcn alternative with live canvas, spec JSON, and industrial primitives.",
  "keywords": [
    "react",
    "charts",
    "dashboard",
    "recharts",
    "shadcn",
    "uplot",
    "echarts",
    "live-charts",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axidify/axicharts.git",
    "directory": "packages/charts"
  },
  "bugs": {
    "url": "https://github.com/Axidify/axicharts/issues"
  },
  "homepage": "https://github.com/Axidify/axicharts#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./line": {
      "types": "./dist/entry/line.d.ts",
      "import": "./dist/entry/line.js"
    },
    "./bar": {
      "types": "./dist/entry/bar.d.ts",
      "import": "./dist/entry/bar.js"
    },
    "./pie": {
      "types": "./dist/entry/pie.d.ts",
      "import": "./dist/entry/pie.js"
    },
    "./area": {
      "types": "./dist/entry/area.d.ts",
      "import": "./dist/entry/area.js"
    },
    "./candlestick": {
      "types": "./dist/entry/candlestick.d.ts",
      "import": "./dist/entry/candlestick.js"
    },
    "./waterfall": {
      "types": "./dist/entry/waterfall.d.ts",
      "import": "./dist/entry/waterfall.js"
    },
    "./heatmap": {
      "types": "./dist/entry/heatmap.d.ts",
      "import": "./dist/entry/heatmap.js"
    },
    "./export": {
      "types": "./dist/entry/export.d.ts",
      "import": "./dist/entry/export.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/registry/index.ts src/entry/line.ts src/entry/bar.ts src/entry/pie.ts src/entry/area.ts src/entry/candlestick.ts src/entry/waterfall.ts src/entry/heatmap.ts src/entry/export.ts --format esm --dts --external react --external react-dom --external uplot --external echarts --external jspdf --clean",
    "dev": "tsup src/index.ts src/registry/index.ts src/entry/line.ts src/entry/bar.ts src/entry/pie.ts src/entry/area.ts src/entry/candlestick.ts src/entry/waterfall.ts src/entry/heatmap.ts src/entry/export.ts --format esm --dts --external react --external react-dom --external uplot --external echarts --external jspdf --watch",
    "create-dashboard": "node scripts/create-dashboard.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "echarts": "^5.5.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "uplot": "^1.6.31"
  },
  "dependencies": {
    "@axicharts/charts-canvas": "workspace:*",
    "@axicharts/charts-core": "workspace:*",
    "@axicharts/charts-echarts": "workspace:*",
    "@axicharts/charts-theme": "workspace:*",
    "jspdf": "^3.0.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "echarts": "^5.6.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "uplot": "^1.6.31",
    "vitest": "^3.0.8"
  }
}
