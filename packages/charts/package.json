{
  "name": "@axicharts/charts",
  "version": "0.2.4",
  "description": "Full-spectrum React charts — line, bar, area, pie, candlestick, waterfall, heatmap, industrial primitives, and extension registry.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axidify/axicharts.git",
    "directory": "packages/charts"
  },
  "bugs": {
    "url": "https://github.com/Axidify/axicharts/issues"
  },
  "homepage": "https://github.com/Axidify/axicharts#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/registry/index.ts --format esm --dts --external react --external react-dom --external uplot --external echarts --clean",
    "dev": "tsup src/index.ts src/registry/index.ts --format esm --dts --external react --external react-dom --external uplot --external echarts --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "echarts": "^5.5.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "uplot": "^1.6.31"
  },
  "dependencies": {
    "@axicharts/charts-canvas": "workspace:*",
    "@axicharts/charts-core": "workspace:*",
    "@axicharts/charts-echarts": "workspace:*",
    "@axicharts/charts-theme": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "echarts": "^5.6.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "uplot": "^1.6.31",
    "vitest": "^3.0.8"
  }
}
