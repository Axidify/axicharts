{
  "name": "@axicharts/charts-planner",
  "version": "0.2.2",
  "description": "Phase 3 server-side dashboard planner — intent parsing, LLM provider hooks, validation with rules fallback.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axidify/axicharts.git",
    "directory": "packages/charts-planner"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "bin": {
    "charts-planner": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server-entry.d.ts",
      "import": "./dist/server-entry.js"
    },
    "./tabular": {
      "types": "./dist/entry/tabular.d.ts",
      "import": "./dist/entry/tabular.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/server-entry.ts src/entry/tabular.ts --format esm --dts --external @axicharts/charts-spec --clean",
    "dev": "tsup src/index.ts src/cli.ts src/server-entry.ts src/entry/tabular.ts --format esm --dts --external @axicharts/charts-spec --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@axicharts/charts-spec": "^0.4.18"
  },
  "devDependencies": {
    "@axicharts/charts-spec": "workspace:*",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
