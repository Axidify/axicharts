{
  "name": "@axicharts/charts-gantt",
  "version": "0.1.0",
  "description": "Community Gantt timeline plugin for AxiCharts — registerChartType extension.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axidify/axicharts.git",
    "directory": "packages/charts-gantt"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/register.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/register.ts --format esm --dts --external react --external react-dom --external @axicharts/charts --external @axicharts/charts-theme --clean",
    "dev": "tsup src/index.ts src/register.ts --format esm --dts --external react --external react-dom --external @axicharts/charts --external @axicharts/charts-theme --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@axicharts/charts-theme": "workspace:*"
  },
  "peerDependencies": {
    "@axicharts/charts": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@axicharts/charts": "workspace:*",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
