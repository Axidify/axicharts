{
  "name": "@axicharts/charts-map",
  "version": "0.3.36",
  "description": "Community TopoJSON choropleth map plugin for AxiCharts — registerChartType extension.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axidify/axicharts.git",
    "directory": "packages/charts-map"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/register.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/register.ts --format esm --dts --external react --external react-dom --external @axicharts/charts --external d3-geo --external topojson-client --clean",
    "dev": "tsup src/index.ts src/register.ts --format esm --dts --external react --external react-dom --external @axicharts/charts --external d3-geo --external topojson-client --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "topojson-client": "^3.1.0"
  },
  "peerDependencies": {
    "@axicharts/charts": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@axicharts/charts": "workspace:*",
    "@testing-library/react": "^16.2.0",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
