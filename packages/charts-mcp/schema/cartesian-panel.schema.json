{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axicharts.dev/schema/cartesian-panel.schema.json",
  "title": "CartesianPanelSpec",
  "description": "RFC-002 cartesian dashboard panel — type cartesian with marks[] only.",
  "type": "object",
  "required": ["type", "encoding", "marks"],
  "additionalProperties": true,
  "properties": {
    "specVersion": { "type": "integer", "const": 1 },
    "type": { "type": "string", "const": "cartesian" },
    "title": { "type": "string" },
    "mode": { "enum": ["static", "interactive", "live"] },
    "theme": { "enum": ["clean", "studio", "live", "dark"] },
    "height": { "type": "number", "minimum": 80 },
    "encoding": {
      "type": "object",
      "required": ["x"],
      "properties": {
        "x": {
          "type": "object",
          "required": ["field"],
          "properties": {
            "field": { "type": "string" },
            "label": { "type": "string" }
          }
        }
      }
    },
    "marks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "field"],
            "properties": {
              "type": { "enum": ["bar", "line", "area"] },
              "field": { "type": "string" },
              "label": { "type": "string" },
              "tone": { "type": "string" },
              "stack": { "type": "string" },
              "labels": { "type": "boolean" },
              "yAxisId": { "type": "string" },
              "curve": { "type": "string" }
            }
          },
          {
            "type": "object",
            "required": ["type", "value"],
            "properties": {
              "type": { "const": "rule" },
              "value": { "type": "number" },
              "label": { "type": "string" },
              "tone": { "type": "string" }
            }
          },
          {
            "type": "object",
            "required": ["type", "min", "max"],
            "properties": {
              "type": { "const": "band" },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "label": { "type": "string" },
              "tone": { "type": "string" }
            }
          }
        ]
      }
    }
  }
}
