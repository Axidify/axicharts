{
  "$schema": "https://axidify.github.io/axicharts/schema/runtime-spec.schema.json",
  "layout": "embed",
  "dashboard": {
    "version": "0.1",
    "title": "Mock live drift",
    "subtitle": "Synthetic telemetry",
    "theme": "industrial",
    "mode": "live",
    "template": "line-overview",
    "dataSource": {
      "type": "mock-live",
      "intervalMs": 1000,
      "data": {
        "categories": ["08:00", "09:00", "10:00", "11:00"],
        "series": [{ "name": "Throughput", "data": [980, 1020, 1100, 1180] }],
        "kpis": [
          { "value": "1.18k", "label": "Units/hr" },
          { "value": "98.2%", "label": "OEE", "tone": "success" }
        ]
      }
    }
  }
}
