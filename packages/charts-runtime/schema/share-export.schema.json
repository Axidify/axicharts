{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axidify.github.io/axicharts/schema/share-export.schema.json",
  "title": "AxiCharts ShareExport",
  "oneOf": [
    { "$ref": "#/$defs/dashboardExport" },
    { "$ref": "#/$defs/workspaceExport" }
  ],
  "$defs": {
    "runtimeSpec": {
      "type": "object"
    },
    "dashboardMeta": {
      "type": "object",
      "properties": {
        "layout": { "type": "string", "enum": ["embed", "mosaic"] },
        "feed": {
          "type": "string",
          "enum": ["static", "historian", "websocket", "mqtt"]
        },
        "template": { "type": "string" },
        "mosaicPreset": { "type": "string" },
        "presentation": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "dashboardExport": {
      "type": "object",
      "required": ["version", "kind", "exportedAt", "name", "spec"],
      "properties": {
        "version": { "const": 1 },
        "kind": { "const": "dashboard" },
        "exportedAt": { "type": "string", "format": "date-time" },
        "name": { "type": "string", "minLength": 1 },
        "meta": { "$ref": "#/$defs/dashboardMeta" },
        "spec": { "$ref": "#/$defs/runtimeSpec" }
      },
      "additionalProperties": false
    },
    "workspaceExport": {
      "type": "object",
      "required": ["version", "kind", "exportedAt", "name", "dashboards"],
      "properties": {
        "version": { "const": 1 },
        "kind": { "const": "workspace" },
        "exportedAt": { "type": "string", "format": "date-time" },
        "name": { "type": "string", "minLength": 1 },
        "dashboards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "spec"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "meta": { "$ref": "#/$defs/dashboardMeta" },
              "spec": { "$ref": "#/$defs/runtimeSpec" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
