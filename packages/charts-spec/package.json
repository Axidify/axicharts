{
  "name": "@axicharts/charts-spec",
  "version": "0.3.37",
  "description": "Layer 2 panel spec compiler and vertical templates for AxiCharts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axidify/axicharts.git",
    "directory": "packages/charts-spec"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "examples"
  ],
  "type": "module",
  "sideEffects": false,
  "bin": {
    "charts-spec": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cartesian": {
      "types": "./dist/entry/cartesian.d.ts",
      "import": "./dist/entry/cartesian.js"
    },
    "./distribution": {
      "types": "./dist/entry/distribution.d.ts",
      "import": "./dist/entry/distribution.js"
    },
    "./financial": {
      "types": "./dist/entry/financial.d.ts",
      "import": "./dist/entry/financial.js"
    },
    "./matrix": {
      "types": "./dist/entry/matrix.d.ts",
      "import": "./dist/entry/matrix.js"
    },
    "./industrial": {
      "types": "./dist/entry/industrial.d.ts",
      "import": "./dist/entry/industrial.js"
    },
    "./kpi": {
      "types": "./dist/entry/kpi.d.ts",
      "import": "./dist/entry/kpi.js"
    },
    "./full": {
      "types": "./dist/entry/full.d.ts",
      "import": "./dist/entry/full.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/entry/cartesian.ts src/entry/distribution.ts src/entry/financial.ts src/entry/matrix.ts src/entry/industrial.ts src/entry/kpi.ts src/entry/full.ts --format esm --dts --external react --external react-dom --external @axicharts/charts --external @axicharts/charts-theme --external @axicharts/charts-sankey --external @axicharts/charts-geo --external @axicharts/charts-map --external @axicharts/charts-gantt --clean",
    "dev": "tsup src/index.ts src/cli.ts src/entry/cartesian.ts src/entry/distribution.ts src/entry/financial.ts src/entry/matrix.ts src/entry/industrial.ts src/entry/kpi.ts src/entry/full.ts --format esm --dts --external react --external react-dom --external @axicharts/charts --external @axicharts/charts-theme --external @axicharts/charts-sankey --external @axicharts/charts-geo --external @axicharts/charts-map --external @axicharts/charts-gantt --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@axicharts/charts": "workspace:*",
    "@axicharts/charts-gantt": "workspace:*",
    "@axicharts/charts-geo": "workspace:*",
    "@axicharts/charts-map": "workspace:*",
    "@axicharts/charts-sankey": "workspace:*",
    "@axicharts/charts-theme": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@axicharts/charts": "workspace:*",
    "@axicharts/charts-gantt": "workspace:*",
    "@axicharts/charts-geo": "workspace:*",
    "@axicharts/charts-map": "workspace:*",
    "@axicharts/charts-sankey": "workspace:*",
    "@axicharts/charts-theme": "workspace:*"
  },
  "devDependencies": {
    "@axicharts/charts-tank": "workspace:*",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "jsdom": "^26.0.0",
    "@napi-rs/canvas": "^1.0.2"
  }
}
