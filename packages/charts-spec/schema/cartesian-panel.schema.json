    },
    "title": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "static",
        "interactive",
        "live"
      ]
    },
    "theme": {
      "enum": [
        "clean",
        "studio",
        "live",
        "dark"
      ]
    },
    "height": {
      "type": "number",
      "minimum": 80
    },
    "encoding": {
      "type": "object",
      "required": [
        "x"
      ],
      "properties": {
        "x": {
          "type": "object",
          "required": [
            "field"
          ],
          "properties": {
            "field": {
              "type": "string"
            },
            "label": {
              "type": "string"
            }
          }
        }
      }
    },
    "marks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/barMark"
          },
          {
            "$ref": "#/$defs/lineMark"
          },
          {
            "$ref": "#/$defs/areaMark"
          },
          {
            "$ref": "#/$defs/ruleMark"
          },
