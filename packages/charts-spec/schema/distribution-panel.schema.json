{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axicharts.dev/schema/distribution-panel.schema.json",
  "title": "DistributionPanelSpec",
  "description": "RFC-004 distribution dashboard panel — type distribution with marks[] only.",
  "type": "object",
  "required": ["type", "encoding", "marks"],
  "additionalProperties": true,
  "properties": {
    "type": { "const": "distribution" },
    "encoding": {
      "type": "object",
      "required": ["angle"],
      "properties": {
        "angle": { "type": "object", "required": ["field"] },
        "color": { "type": "object" }
      }
    },
    "marks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["mark", "field"],
            "properties": {
              "mark": { "const": "arc" },
              "field": { "type": "string" }
            }
          },
          {
            "type": "object",
            "required": ["mark", "field"],
            "properties": {
              "mark": { "const": "funnel" },
              "field": { "type": "string" },
              "sort": { "enum": ["ascending", "descending", "none"] }
            }
          },
          {
            "type": "object",
            "required": ["mark"],
            "properties": {
              "mark": { "const": "donut" },
              "innerRadius": { "type": "number" }
            }
          },
          {
            "type": "object",
            "required": ["mark", "dataKey"],
            "properties": {
              "mark": { "const": "cell" },
              "dataKey": { "type": "string" }
            }
          },
          {
            "type": "object",
            "required": ["mark"],
            "properties": {
              "mark": { "const": "label" },
              "show": { "type": "boolean" },
              "position": { "enum": ["inside", "outside"] }
            }
          }
        ]
      }
    }
  }
}
