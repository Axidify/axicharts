{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axicharts.dev/schema/data-profile.schema.json",
  "title": "DataProfile",
  "description": "Known metrics and row fields for cartesian planner and MCP tools.",
  "type": "object",
  "required": [
    "metrics"
  ],
  "additionalProperties": false,
  "properties": {
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "gauge",
              "counter",
              "histogram",
              "ohlc",
              "distribution"
            ]
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fieldProfiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "role": {
            "enum": ["time", "dimension", "measure", "identifier"]
          },
          "format": {
            "enum": ["number", "currency", "percent", "compact"]
          }
        }
      }
    }
  }
}
