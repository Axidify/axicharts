{
  "name": "@axicharts/charts-canvas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react --external react-dom --external uplot --clean",
    "dev": "tsup src/index.ts --format esm --dts --external react --external react-dom --external uplot --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "uplot": "^1.6.31"
  },
  "dependencies": {
    "@axicharts/charts-core": "workspace:*",
    "@axicharts/charts-theme": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "uplot": "^1.6.31"
  }
}
