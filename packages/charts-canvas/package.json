{
  "name": "@axicharts/charts-canvas",
  "version": "0.2.14",
  "description": "uPlot canvas adapters for AxiCharts line and bar charts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axidify/axicharts.git",
    "directory": "packages/charts-canvas"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react --external react-dom --external uplot --clean",
    "dev": "tsup src/index.ts --format esm --dts --external react --external react-dom --external uplot --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:perf": "vitest run --config vitest.perf.config.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "uplot": "^1.6.31"
  },
  "dependencies": {
    "@axicharts/charts-core": "workspace:*",
    "@axicharts/charts-theme": "workspace:*"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@types/react": "^19.0.10",
    "happy-dom": "^20.10.6",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "uplot": "^1.6.31",
    "vitest": "^3.0.8"
  }
}
