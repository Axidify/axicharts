    "@axicharts/charts-geo": "workspace:*",
    "@axicharts/charts-planner": "workspace:*",
    "@axicharts/charts-runtime": "workspace:*",
    "@axicharts/charts-sankey": "workspace:*",
    "@axicharts/charts-spec": "workspace:*",
    "@axicharts/charts-tank": "workspace:*",
    "@axicharts/charts-theme": "workspace:*",
    "@tailwindcss/vite": "^4.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^5.6.0",
    "lucide-react": "^1.25.0",
    "pg": "^8.14.1",
    "radix-ui": "^1.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "uplot": "^1.6.31",
    "zod": "^3.25.76"
