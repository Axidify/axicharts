{
  "name": "@axicharts/axiboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "build": "vite build && pnpm run build:server",
    "build:server": "tsup --config tsup.server.config.ts",
    "start": "node dist-server/index.js",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@axicharts/charts": "workspace:*",
    "@axicharts/charts-andon": "workspace:*",
    "@axicharts/charts-geo": "workspace:*",
    "@axicharts/charts-runtime": "workspace:*",
    "@axicharts/charts-sankey": "workspace:*",
    "@axicharts/charts-spec": "workspace:*",
    "@axicharts/charts-planner": "workspace:*",
    "@axicharts/charts-tank": "workspace:*",
    "@axicharts/charts-theme": "workspace:*",
    "echarts": "^5.6.0",
    "pg": "^8.14.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@axicharts/charts-mcp": "workspace:*",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.8"
  }
}
